PORT=4000
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development

# Database
# Use "auto" for local development fallback, "mongo" for production, or "file" for local JSON storage.
DB_MODE=auto
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=coronahub
FILE_DB_PATH=
ALLOW_FILE_DB_IN_PRODUCTION=false

# Admin panel
JWT_SECRET=change_this_to_a_long_random_secret
ADMIN_EMAIL=admin@coronahub.local
ADMIN_PASSWORD=change_this_password
IP_HASH_SALT=change_this_salt

# Telegram notifications and moderation. Leave empty to disable.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_BASE_URL=
TELEGRAM_WEBHOOK_TOKEN=
TELEGRAM_POLLING_ENABLED=false
